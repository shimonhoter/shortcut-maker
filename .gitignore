# =============================================================
# ShortcutMaker – .gitignore
# =============================================================

# ── Gradle build outputs ──────────────────────────────────────
.gradle/
build/
app/build/
**/build/

# ── Local config files (machine-specific) ────────────────────
local.properties
*.local.properties

# ── Android Studio / IntelliJ ────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.DS_Store
captures/
.externalNativeBuild/
.cxx/

# ── Gradle wrapper JAR (binary, regenerated on first build) ──
gradle/wrapper/gradle-wrapper.jar

# ── Signing keystores – NEVER commit these ───────────────────
*.jks
*.keystore
keystore.properties
release.properties

# חריג מכוון: ה-debug keystore חייב להיות ב-repo כדי שכל
# build ב-CI יחתום עם אותו מפתח קבוע (אחרת כל build מקבל
# מפתח אקראי חדש וגורם לכשל "בעיה בניתוח החבילה" בהתקנה)
!keystore/debug.keystore

# ── Generated APKs / AABs ────────────────────────────────────
*.apk
*.aab
*.ap_

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── OS junk ──────────────────────────────────────────────────
Thumbs.db
Desktop.ini
.Spotlight-V100
.Trashes

# ── Termux-specific ──────────────────────────────────────────
# Don't commit Termux home paths that are machine-specific
.termux/
